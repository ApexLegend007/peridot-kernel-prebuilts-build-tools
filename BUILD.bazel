load("@rules_pkg//pkg:mappings.bzl", "pkg_files", "strip_prefix")
load(":cc.bzl", "import_libraries")
load(":prebuilt_tool.bzl", "prebuilt_tool")

# Source files referenced directly by msm-kernel bzl files need explicit
# visibility since Bazel restricts auto-generated source file targets to the
# declaring package by default.
exports_files(
    glob(["linux-x86/bin/*"]),
    visibility = ["//visibility:public"],
)

_SHARED_LIBS = glob(["linux-x86/lib64/*.so"])

_MUSL_SHARED_LIBS = glob(["linux_musl-x86/lib64/*.so"])

filegroup(
    name = "linux-x86",
    srcs = glob(["linux-x86/**"]),
    visibility = ["//visibility:public"],
)

filegroup(
    name = "linux-x86-libs",
    srcs = _SHARED_LIBS,
    visibility = ["//visibility:public"],
)

filegroup(
    name = "linux_musl-x86-libs",
    srcs = _MUSL_SHARED_LIBS,
    visibility = ["//visibility:private"],
)

# Used in prebuilt_tool()
alias(
    name = "libs",
    actual = select({
        "//build/kernel/kleaf/platforms/libc:glibc": ":linux-x86-libs",
        "//build/kernel/kleaf/platforms/libc:musl": ":linux_musl-x86-libs",
    }),
    target_compatible_with = select({
        "//build/kernel/kleaf/platforms/libc:glibc": [],
        "//build/kernel/kleaf/platforms/libc:musl": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    visibility = [
        "@kleaf_clang_toolchain//:__subpackages__",
    ],
)

import_libraries(
    name = "linux_x86_imported_libs",
    hdrs = glob(["linux-x86/include/**/*.h"]),
    shared_libraries = _SHARED_LIBS,
    strip_include_prefix = "linux-x86/include",
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
    visibility = ["//visibility:public"],
)

import_libraries(
    name = "linux_musl_x86_imported_libs",
    hdrs = glob(["linux_musl-x86/include/**/*.h"]),
    shared_libraries = _MUSL_SHARED_LIBS,
    strip_include_prefix = "linux_musl-x86/include",
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "//build/kernel/kleaf/platforms/libc:musl",
    ],
    visibility = ["//visibility:private"],
)

alias(
    name = "imported_libs",
    actual = select({
        "//build/kernel/kleaf/platforms/libc:glibc": ":linux_x86_imported_libs",
        "//build/kernel/kleaf/platforms/libc:musl": ":linux_musl_x86_imported_libs",
    }),
    visibility = ["//build/kernel/kleaf:__subpackages__"],
)

filegroup(
    name = "runpath",
    srcs = select({
        "//build/kernel/kleaf/platforms/libc:glibc": ["linux-x86/lib64"],
        "//build/kernel/kleaf/platforms/libc:musl": ["linux_musl-x86/lib64"],
    }),
    visibility = ["//build/kernel/kleaf:__subpackages__"],
)

import_libraries(
    name = "linux_x86_libcrypto",
    hdrs = glob(["linux-x86/include/openssl/*.h"]),
    shared_libraries = ["linux-x86/lib64/libcrypto-host.so"],
    strip_include_prefix = "linux-x86/include",
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "//build/kernel/kleaf/platforms/libc:glibc",
    ],
    visibility = ["//visibility:private"],
)

import_libraries(
    name = "linux_x86_musl_libcrypto",
    hdrs = glob(["linux_musl-x86/include/openssl/*.h"]),
    shared_libraries = ["linux_musl-x86/lib64/libcrypto-host.so"],
    strip_include_prefix = "linux_musl-x86/include",
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
        "//build/kernel/kleaf/platforms/libc:musl",
    ],
    visibility = ["//visibility:private"],
)

alias(
    name = "libcrypto",
    actual = select({
        "//build/kernel/kleaf/platforms/libc:glibc": ":linux_x86_libcrypto",
        "//build/kernel/kleaf/platforms/libc:musl": ":linux_x86_musl_libcrypto",
    }),
    visibility = ["@toybox//:__subpackages__"],
)

filegroup(
    name = "musl_sysroot_files",
    srcs = glob([
        "sysroots/x86_64-unknown-linux-musl/include/**",
        "sysroots/x86_64-unknown-linux-musl/lib/**",
    ]),
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
    visibility = [
        "@kleaf_clang_toolchain//:__subpackages__",
    ],
)

filegroup(
    name = "musl_sysroot_dir",
    srcs = ["sysroots/x86_64-unknown-linux-musl"],
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
    visibility = [
        "@kleaf_clang_toolchain//:__subpackages__",
    ],
)

filegroup(
    name = "libc_musl_file",
    srcs = ["sysroots/x86_64-unknown-linux-musl/lib/libc_musl.so"],
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
    visibility = ["@kleaf_clang_toolchain//:__subpackages__"],
)

filegroup(
    name = "swig_lib_dir",
    srcs = select({
        "//build/kernel/kleaf/platforms/libc:glibc": ["linux-x86/share/swig"],
        "//build/kernel/kleaf/platforms/libc:musl": ["linux_musl-x86/share/swig"],
    }),
    visibility = ["//build/kernel:__subpackages__"],
)

